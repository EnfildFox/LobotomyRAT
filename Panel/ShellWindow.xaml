<!-- ShellWindow.xaml -->
<Window x:Class="SafeOps.Panel.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shell" Height="500" Width="800"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <RichTextBox x:Name="OutputBox" IsReadOnly="True" FontFamily="Consolas" FontSize="12" Margin="5"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5">
            <TextBox x:Name="CommandBox" Height="25" Width="200"/>
            <Button Content="Send" Click="SendButton_Click" Width="60" Margin="5,0,0,0"/>
            <Button Content="Clear" Click="ClearButton_Click" Width="60" Margin="5,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>