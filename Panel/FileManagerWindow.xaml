<!-- Panel/FileManagerWindow.xaml -->
<Window x:Class="SafeOps.Panel.FileManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="File Manager - {Binding Bot.Hostname}" Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E" Foreground="#E0E0E0">
    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Левая панель: дерево директорий (упрощённо, для примера) -->
        <Border Grid.RowSpan="2" Grid.Column="0" Background="#2D2D2D" BorderBrush="#555" BorderThickness="1" CornerRadius="5" Margin="0,0,5,0">
            <TreeView x:Name="DirectoryTreeView" Background="Transparent" BorderThickness="0" Margin="5" SelectedItemChanged="TreeView_SelectedItemChanged"/>
        </Border>

        <!-- Правая панель: список файлов -->
        <Border Grid.Column="1" Grid.RowSpan="2" Background="#2D2D2D" BorderBrush="#555" BorderThickness="1" CornerRadius="5" Margin="5,0,0,0">
            <DataGrid x:Name="FilesGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                      SelectionMode="Single" Background="Transparent" 
                      BorderThickness="0" RowBackground="#2D2D2D" AlternatingRowBackground="#3A3A3A"
                      Foreground="#E0E0E0"
                      MouseDoubleClick="FilesGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                    <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="1*"/>
                    <DataGridTextColumn Header="Modified" Binding="{Binding Modified}" Width="1.5*"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="1*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Нижняя панель: действия -->
        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,5,0,0">
            <TextBox x:Name="CurrentPathTextBox" IsReadOnly="True" Width="300" Margin="0,0,10,0" VerticalAlignment="Center"/>
            <Button x:Name="UploadButton" Content="Upload" Click="UploadButton_Click" Width="80" Margin="0,0,5,0"/>
            <Button x:Name="DownloadButton" Content="Download" Click="DownloadButton_Click" Width="80" Margin="0,0,5,0"/>
            <Button x:Name="DeleteButton" Content="Delete" Click="DeleteButton_Click" Width="80" Margin="0,0,5,0"/>
            <Button x:Name="NewFolderButton" Content="New Folder" Click="NewFolderButton_Click" Width="90" Margin="0,0,5,0"/>
            <Button x:Name="RefreshButton" Content="Refresh" Click="RefreshButton_Click" Width="80"/>
        </StackPanel>
    </Grid>
</Window>